# App
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
API_URL=http://localhost:3001

# Database (Neon)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_URL=postgresql://user:pass@host/db?sslmode=require

# Auth
AUTH_SECRET=change-me-to-a-random-64-char-string
COOKIE_DOMAIN=localhost

# Redis (Upstash)
REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=MedFlow <noreply@medflow.com>

# Video (LiveKit)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=medflow-documents
R2_PUBLIC_URL=https://documents.medflow.com

# Frontend
FRONTEND_URL=http://localhost:3000

# Encryption
ENCRYPTION_KEY=change-me-to-a-random-32-char-hex-string
